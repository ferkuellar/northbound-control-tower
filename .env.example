APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5433
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

POSTGRES_USER=nct
POSTGRES_PASSWORD=nct_dev_password
POSTGRES_DB=nct
DATABASE_URL=postgresql+psycopg://nct:nct_dev_password@postgres:5432/nct
REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
OBSERVABILITY_ENABLED=true
PROMETHEUS_METRICS_ENABLED=true
OTEL_TRACING_ENABLED=true
OTEL_SERVICE_NAME=northbound-control-tower-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO
LOG_FORMAT=json
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_AI_PER_MINUTE=10
RATE_LIMIT_REPORTS_PER_MINUTE=5
RATE_LIMIT_INVENTORY_SCAN_PER_MINUTE=5
PASSWORD_MIN_LENGTH=12

JWT_SECRET_KEY=change-this-local-development-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

AWS_DEFAULT_REGION=us-east-1
AWS_SCAN_TIMEOUT_SECONDS=300

OCI_DEFAULT_REGION=us-ashburn-1
OCI_SCAN_TIMEOUT_SECONDS=300

AI_PROVIDER=none
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_INPUT_FINDINGS=50
AI_MAX_INPUT_RESOURCES=100
AI_MAX_TOKENS=2500
AI_TEMPERATURE=0.2
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
