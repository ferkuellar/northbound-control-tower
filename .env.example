APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5433
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

POSTGRES_USER=nct
# required — never leave empty in staging/production
# generate: openssl rand -base64 24
POSTGRES_PASSWORD=
POSTGRES_DB=nct
# required — set password segment to match POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://nct:CHANGEME@postgres:5432/nct
REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
OBSERVABILITY_ENABLED=true
PROMETHEUS_METRICS_ENABLED=true
OTEL_TRACING_ENABLED=true
OTEL_SERVICE_NAME=northbound-control-tower-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=INFO
LOG_FORMAT=json
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_AI_PER_MINUTE=10
RATE_LIMIT_REPORTS_PER_MINUTE=5
RATE_LIMIT_INVENTORY_SCAN_PER_MINUTE=5
PASSWORD_MIN_LENGTH=12

# required — generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# Cloud Shell is disabled by default.
# Enable only in explicitly approved environments.
CLOUD_SHELL_ENABLED=false
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

AWS_DEFAULT_REGION=us-east-1
AWS_SCAN_TIMEOUT_SECONDS=300

OCI_DEFAULT_REGION=us-ashburn-1
OCI_SCAN_TIMEOUT_SECONDS=300

# Secret provider selection.
# Development/test: env (reads from process environment / .env file).
# Production: set SECRET_PROVIDER=oci and configure OCI_VAULT_ID.
SECRET_PROVIDER=env

# Required in production. OCID of the OCI Vault holding production secrets.
# Production startup will fail if APP_ENV=production and OCI_VAULT_ID is not set.
# Example: ocid1.vault.oc1.iad.entzsljraafoo.abcdef...
OCI_VAULT_ID=

# AI provider is disabled by default for safe local startup.
# To enable Claude in development/demo, copy this file to .env and set:
#   AI_PROVIDER=claude
#   ANTHROPIC_API_KEY=sk-ant-api03-your-real-key
AI_PROVIDER=none
ANTHROPIC_API_KEY=

# Claude provider configuration.
CLAUDE_MODEL=claude-sonnet-4-6

# 4000 helps avoid truncating structured JSON responses for full_assessment.
AI_MAX_TOKENS=4000

# Low temperature improves deterministic structured JSON output.
AI_TEMPERATURE=0.2

# Claude full assessments may take 60+ seconds.
AI_REQUEST_TIMEOUT_SECONDS=90

AI_MAX_INPUT_FINDINGS=50
AI_MAX_INPUT_RESOURCES=100
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GRAFANA_ADMIN_USER=admin
# required — never leave as "admin" in staging/production
GRAFANA_ADMIN_PASSWORD=
